<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{name}} — {{role}}</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Josefin+Sans:wght@300;400;600&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --ink: #1a1410;
            --paper: #faf8f4;
            --cream: #f0ebe0;
            --gold: #b8924a;
            --gold-light: #d4aa6a;
            --muted: #8a7d6e;
            --border: #ddd8cc;
            --rule: #c8bfad;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Cormorant Garamond', serif;
            background: var(--paper);
            color: var(--ink);
            font-size: 17px;
            line-height: 1.7;
        }

        .ornament {
            display: inline-block;
            color: var(--gold);
            font-size: 1.2em;
            margin: 0 0.5rem;
            opacity: 0.7;
        }

        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            background: rgba(250, 248, 244, 0.94);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
        }

        .nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }

        .nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--ink);
            text-decoration: none;
            letter-spacing: 0.02em;
        }

        .nav-divider {
            width: 1px;
            height: 28px;
            background: var(--rule);
            margin: 0 2rem;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
            align-items: center;
        }

        .nav-links a {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 600;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--gold);
        }

        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 8rem 3rem 6rem;
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
        }

        .hero-inner {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 420px;
            gap: 6rem;
            align-items: center;
        }

        .hero-eyebrow {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.65rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1.8rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .hero-eyebrow::before,
        .hero-eyebrow::after {
            content: '';
            height: 1px;
            background: var(--gold);
            opacity: 0.5;
        }

        .hero-eyebrow::before {
            width: 3rem;
        }

        .hero-eyebrow::after {
            width: 1.5rem;
        }

        .hero-name {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3.5rem, 7vw, 6.5rem);
            font-weight: 900;
            line-height: 0.95;
            letter-spacing: -0.03em;
            margin-bottom: 1.5rem;
        }

        .hero-name em {
            font-style: italic;
            color: var(--gold);
        }

        .hero-rule {
            width: 5rem;
            height: 2px;
            background: linear-gradient(to right, var(--gold), transparent);
            margin: 1.5rem 0;
        }

        .hero-role {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.85rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--muted);
            font-weight: 300;
            margin-bottom: 2rem;
        }

        .hero-summary {
            font-size: 1.15rem;
            color: #4a4035;
            line-height: 1.85;
            max-width: 520px;
            font-weight: 300;
            margin-bottom: 3rem;
        }

        .hero-contacts {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .hero-contacts a {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.68rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ink);
            text-decoration: none;
            border: 1px solid var(--rule);
            padding: 0.65rem 1.4rem;
            transition: all 0.25s;
        }

        .hero-contacts a:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(184, 146, 74, 0.05);
        }

        /* Hero portrait block */
        .hero-portrait {
            position: relative;
        }

        .portrait-frame {
            width: 100%;
            aspect-ratio: 3/4;
            background: var(--cream);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }

        .portrait-frame::before {
            content: attr(data-initials);
            font-family: 'Playfair Display', serif;
            font-size: 11rem;
            font-weight: 900;
            font-style: italic;
            color: rgba(184, 146, 74, 0.1);
            position: absolute;
            bottom: -2rem;
            right: -1rem;
            line-height: 1;
            user-select: none;
        }

        .portrait-corner {
            position: absolute;
            width: 20px;
            height: 20px;
            border-color: var(--gold);
            border-style: solid;
            opacity: 0.6;
        }

        .portrait-corner.tl {
            top: 12px;
            left: 12px;
            border-width: 1px 0 0 1px;
        }

        .portrait-corner.tr {
            top: 12px;
            right: 12px;
            border-width: 1px 1px 0 0;
        }

        .portrait-corner.bl {
            bottom: 12px;
            left: 12px;
            border-width: 0 0 1px 1px;
        }

        .portrait-corner.br {
            bottom: 12px;
            right: 12px;
            border-width: 0 1px 1px 0;
        }

        .portrait-label {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.6rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .portrait-accent {
            position: absolute;
            bottom: -1.5rem;
            right: -1.5rem;
            width: 120px;
            height: 120px;
            border: 1px solid var(--border);
            background: var(--gold);
            opacity: 0.08;
            z-index: -1;
        }

        .page-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 3rem;
        }

        section {
            border-top: 1px solid var(--border);
            padding: 7rem 0;
        }

        .section-header {
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 3rem;
            margin-bottom: 4rem;
            align-items: start;
        }

        .section-meta {
            padding-top: 0.4rem;
        }

        .section-number {
            font-family: 'Playfair Display', serif;
            font-size: 0.7rem;
            color: var(--gold);
            letter-spacing: 0.15em;
            margin-bottom: 0.5rem;
            font-style: italic;
        }

        .section-label-text {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--muted);
        }

        .section-vr {
            width: 1px;
            background: var(--rule);
            align-self: stretch;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 4vw, 3.2rem);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -0.02em;
        }

        .section-title em {
            font-style: italic;
            color: var(--gold);
        }

        .skills-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .skill-tag {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 0.5rem 1.2rem;
            border: 1px solid var(--rule);
            background: transparent;
            color: var(--muted);
            cursor: default;
            transition: all 0.2s;
            font-weight: 400;
        }

        .skill-tag:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(184, 146, 74, 0.04);
        }

        .timeline {
            position: relative;
        }

        .timeline-rule {
            position: absolute;
            left: 190px;
            top: 0;
            bottom: 0;
            width: 1px;
            background: var(--border);
        }

        .exp-item {
            display: grid;
            grid-template-columns: 190px 1fr;
            gap: 3rem;
            padding: 3rem 0;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .exp-item:last-child {
            border-bottom: none;
        }

        .exp-item::after {
            content: '';
            position: absolute;
            left: 186px;
            top: 3.5rem;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: var(--paper);
            border: 1px solid var(--rule);
            z-index: 1;
            transition: all 0.2s;
        }

        .exp-item:hover::after {
            background: var(--gold);
            border-color: var(--gold);
        }

        .exp-aside {
            text-align: right;
            padding-top: 0.25rem;
        }

        .exp-period {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.65rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--gold);
            font-weight: 400;
            line-height: 1.4;
        }

        .exp-company-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.9rem;
            color: var(--muted);
            margin-top: 0.4rem;
            font-style: italic;
        }

        .exp-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
            line-height: 1.2;
        }

        .exp-responsibilities {
            list-style: none;
            margin-bottom: 1.5rem;
        }

        .exp-responsibilities li {
            font-size: 1rem;
            color: #4a4035;
            line-height: 1.7;
            padding-left: 1.5rem;
            position: relative;
            margin-bottom: 0.4rem;
            font-weight: 300;
        }

        .exp-responsibilities li::before {
            content: '◆';
            position: absolute;
            left: 0;
            color: var(--gold);
            font-size: 0.45rem;
            top: 0.6rem;
        }

        .exp-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .tech-tag {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.6rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 0.2rem 0.7rem;
            border: 1px solid var(--border);
            color: var(--muted);
            font-weight: 300;
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 2px;
            background: var(--border);
        }

        .project-card {
            background: var(--paper);
            padding: 3rem;
            position: relative;
            transition: background 0.3s;
        }

        .project-card:hover {
            background: var(--cream);
        }

        .project-number {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 900;
            font-style: italic;
            color: rgba(184, 146, 74, 0.12);
            line-height: 1;
            margin-bottom: 1.5rem;
        }

        .project-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 1.2rem;
        }

        .project-highlights {
            list-style: none;
            margin-bottom: 1.5rem;
        }

        .project-highlights li {
            font-size: 0.95rem;
            color: #4a4035;
            line-height: 1.65;
            padding-left: 1.4rem;
            position: relative;
            margin-bottom: 0.35rem;
            font-weight: 300;
        }

        .project-highlights li::before {
            content: '—';
            position: absolute;
            left: 0;
            color: var(--gold);
        }

        footer {
            border-top: 1px solid var(--border);
            padding: 3.5rem 3rem;
        }

        .footer-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 700;
        }

        .footer-meta {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.6rem;
            color: var(--muted);
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-weight: 300;
        }

        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: none;
        }

        @media (max-width: 900px) {
            .nav-inner {
                padding: 0 1.5rem;
            }

            .hero {
                padding: 7rem 1.5rem 4rem;
            }

            .hero-inner {
                grid-template-columns: 1fr;
            }

            .portrait-frame {
                display: none;
            }

            .page-wrap {
                padding: 0 1.5rem;
            }

            section {
                padding: 4rem 0;
            }

            .section-header {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .section-vr {
                display: none;
            }

            .timeline-rule {
                left: 0;
                display: none;
            }

            .exp-item {
                grid-template-columns: 1fr;
                gap: 0.5rem;
            }

            .exp-aside {
                text-align: left;
            }

            .exp-item::after {
                display: none;
            }

            footer {
                padding: 2.5rem 1.5rem;
            }
        }
    </style>
</head>

<body>
    <nav>
        <div class="nav-inner">
            <a href="#" class="nav-logo">{{name}}</a>
            <div class="nav-divider"></div>
            <ul class="nav-links">
                {{#if skills}}<li><a href="#skills">{{@root.labels.skills}}</a></li>{{/if}}
                {{#if experiences}}<li><a href="#experience">{{@root.labels.experience}}</a></li>{{/if}}
                {{#if projects}}<li><a href="#projects">{{@root.labels.projects}}</a></li>{{/if}}
            </ul>
        </div>
    </nav>

    <div class="page-wrap">
        <section class="hero" id="home" style="border: none; padding-top: 8rem;">
            <div class="hero-inner">
                <div class="hero-text reveal">
                    <p class="hero-eyebrow">Portfólio</p>
                    <h1 class="hero-name">{{name}}</h1>
                    <div class="hero-rule"></div>
                    <p class="hero-role">{{role}}</p>
                    {{#if summary}}<p class="hero-summary">{{summary}}</p>{{/if}}
                    {{#if contactsHtml}}
                    <div class="hero-contacts">{{{contactsHtml}}}</div>
                    {{/if}}
                </div>
                <div class="hero-portrait reveal" style="transition-delay: 0.15s;">
                    <div class="portrait-frame" data-initials="{{initials}}">
                        <span class="portrait-label">{{role}}</span>
                        <div class="portrait-corner tl"></div>
                        <div class="portrait-corner tr"></div>
                        <div class="portrait-corner bl"></div>
                        <div class="portrait-corner br"></div>
                    </div>
                    <div class="portrait-accent"></div>
                </div>
            </div>
        </section>

        {{#if skills}}
        <section id="skills">
            <div class="reveal">
                <div class="section-header">
                    <div class="section-meta">
                        <p class="section-number">I.</p>
                        <p class="section-label-text">{{@root.labels.skills}}</p>
                    </div>
                    <div>
                        <h2 class="section-title">Ferramentas &amp;<br><em>Tecnologias</em></h2>
                    </div>
                </div>
                <div class="skills-grid">
                    {{#each skills}}
                    <span class="skill-tag">{{this}}</span>
                    {{/each}}
                </div>
            </div>
        </section>
        {{/if}}

        {{#if experiences}}
        <section id="experience">
            <div class="reveal">
                <div class="section-header">
                    <div class="section-meta">
                        <p class="section-number">II.</p>
                        <p class="section-label-text">{{@root.labels.experience}}</p>
                    </div>
                    <div>
                        <h2 class="section-title">Trajetória<br><em>Profissional</em></h2>
                    </div>
                </div>
                <div class="timeline">
                    <div class="timeline-rule"></div>
                    {{#each experiences}}
                    <div class="exp-item reveal">
                        <div class="exp-aside">
                            <p class="exp-period">{{period}}</p>
                            <p class="exp-company-name">{{company}}</p>
                        </div>
                        <div>
                            <h3 class="exp-title">{{title}}</h3>
                            {{#if responsibilities}}
                            <ul class="exp-responsibilities">
                                {{#each responsibilities}}
                                <li>{{this}}</li>
                                {{/each}}
                            </ul>
                            {{/if}}
                            {{#if technologies}}
                            <div class="exp-tech">
                                {{#each technologies}}
                                <span class="tech-tag">{{this}}</span>
                                {{/each}}
                            </div>
                            {{/if}}
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
        </section>
        {{/if}}

        {{#if projects}}
        <section id="projects">
            <div class="reveal">
                <div class="section-header">
                    <div class="section-meta">
                        <p class="section-number">III.</p>
                        <p class="section-label-text">{{@root.labels.projects}}</p>
                    </div>
                    <div>
                        <h2 class="section-title">Projetos<br><em>Selecionados</em></h2>
                    </div>
                </div>
                <div class="projects-grid">
                    {{#each projects}}
                    <div class="project-card reveal">
                        <p class="project-number">0{{@index}}</p>
                        <h3 class="project-name">{{name}}</h3>
                        {{#if highlights}}
                        <ul class="project-highlights">
                            {{#each highlights}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                        {{/if}}
                        {{#if technologies}}
                        <div class="exp-tech">
                            {{#each technologies}}
                            <span class="tech-tag">{{this}}</span>
                            {{/each}}
                        </div>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
            </div>
        </section>
        {{/if}}
    </div>

    <footer>
        <div class="footer-inner">
            <span class="footer-brand">{{name}}</span>
            <span class="footer-meta">{{role}}</span>
        </div>
    </footer>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        document.querySelectorAll('.skills-grid, .projects-grid').forEach(grid => {
            [...grid.children].forEach((child, i) => {
                child.style.transitionDelay = `${i * 0.05}s`;
            });
        });
    </script>
</body>

</html>