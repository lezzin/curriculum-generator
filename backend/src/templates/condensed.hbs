<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>{{name}} - {{role}}</title>
  <style>
    @page {
      size: A4;
      margin: 15mm;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11px;
      line-height: 1.3;
      margin: 0;
      color: #000;
    }

    h1 {
      font-size: 18pt;
      margin: 0;
    }

    h2 {
      font-size: 12pt;
      font-weight: normal;
      margin: 2px 0 6px 0;
    }

    h3 {
      font-size: 11pt;
      margin: 12px 0 4px 0;
      text-transform: uppercase;
    }

    p,
    ul {
      margin: 2px 0 4px 0;
    }

    ul {
      padding-left: 14px;
    }

    .section {
      margin-bottom: 8px;
    }

    .skills-line {
      font-size: 10pt;
    }

    .job-title {
      font-weight: bold;
    }

    .company-period {
      font-style: italic;
      font-size: 10pt;
    }
  </style>
</head>

<body>

  <header class="section">
    <h1>{{name}}</h1>
    <h2>{{role}}</h2>
    {{#if contactsHtml}}<p>{{{contactsHtml}}}</p>{{/if}}
    {{#if summary}}<p>{{summary}}</p>{{/if}}
  </header>

  {{#if skills}}
  <section class="section">
    <h3>{{@root.labels.skills}}</h3>
    <p class="skills-line">{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
  </section>
  {{/if}}

  {{#if experiences}}
  <section class="section">
    <h3>{{@root.labels.experience}}</h3>
    {{#each experiences}}
    <div class="section">
      <p class="job-title">{{title}}</p>
      <p class="company-period">{{company}} | {{period}}</p>
      {{#if responsibilities}}
      <ul>{{#each responsibilities}}<li>{{this}}</li>{{/each}}</ul>
      {{/if}}
      {{#if technologies}}
      <p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless @last}},
        {{/unless}}{{/each}}</p>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if projects}}
  <section class="section">
    <h3>{{@root.labels.projects}}</h3>
    {{#each projects}}
    <div class="section">
      <p class="job-title">{{name}}</p>
      {{#if highlights}}<ul>{{#each highlights}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
      {{#if technologies}}
      <p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless @last}},
        {{/unless}}{{/each}}</p>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

</body>

</html>