<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>{{name}} - {{role}}</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 12px;
      line-height: 1.5;
      color: #000;
      margin: 20mm;
    }

    h1 {
      font-size: 22pt;
      margin: 0 0 4px 0;
    }

    h2 {
      font-size: 13pt;
      margin: 0 0 12px 0;
      font-weight: normal;
    }

    h3 {
      font-size: 12pt;
      margin: 16px 0 6px 0;
      text-transform: uppercase;
      border-bottom: 1px solid #000;
      padding-bottom: 2px;
    }

    p {
      margin: 4px 0 8px 0;
    }

    ul {
      margin: 4px 0 8px 18px;
      padding: 0;
    }

    li {
      margin-bottom: 3px;
    }

    .section {
      margin-bottom: 14px;
    }

    .job-title {
      font-weight: bold;
    }

    .company-period {
      font-style: italic;
    }

    .contact {
      margin-bottom: 10px;
    }
  </style>
</head>

<body>

  <header class="section">
    <h1>{{name}}</h1>
    <h2>{{role}}</h2>
    {{#if contacts}}<p class="contact">{{formatContacts contacts format}}</p>{{/if}}
    {{#if summary}}<p>{{summary}}</p>{{/if}}
  </header>

  {{#if skills}}
  <section class="section">
    <h3>{{@root.labels.skills}}</h3>
    <ul>{{#each skills}}<li>{{this}}</li>{{/each}}</ul>
  </section>
  {{/if}}

  {{#if experiences}}
  <section class="section">
    <h3>{{@root.labels.experience}}</h3>
    {{#each experiences}}
    <div class="section">
      <p class="job-title">{{title}}</p>
      <p class="company-period">{{company}} | {{period}}</p>
      {{#if responsibilities}}<ul>{{#each responsibilities}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
      {{#if technologies}}<p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless
        @last}}, {{/unless}}{{/each}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if projects}}
  <section class="section">
    <h3>{{@root.labels.projects}}</h3>
    {{#each projects}}
    <div class="section">
      <p class="job-title">{{name}}</p>
      {{#if highlights}}<ul>{{#each highlights}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
      {{#if technologies}}<p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless
        @last}}, {{/unless}}{{/each}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

</body>

</html>