<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>{{name}} - {{role}}</title>
  <style>
    @page {
      size: A4;
      margin: 20mm;
    }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 12px;
      line-height: 1.5;
      margin: 0;
      color: #222;
      background: #fff;
    }

    header {
      border-bottom: 2px solid #4CAF50;
      padding-bottom: 6px;
      margin-bottom: 12px;
    }

    h1 {
      font-size: 22pt;
      color: #4CAF50;
      margin: 0;
    }

    h2 {
      font-size: 14pt;
      font-weight: normal;
      margin: 2px 0 6px 0;
    }

    h3 {
      font-size: 12pt;
      background: #f2f2f2;
      padding: 2px 6px;
      margin: 12px 0 4px 0;
      text-transform: uppercase;
    }

    h4 {
      font-size: 11pt;
      margin: 2px 0;
    }

    p,
    ul {
      margin: 2px 0 6px 0;
    }

    ul {
      padding-left: 18px;
    }

    li {
      margin-bottom: 2px;
    }

    .section {
      margin-bottom: 14px;
    }

    .job-title {
      font-weight: bold;
      color: #333;
    }

    .company-period {
      font-style: italic;
      font-size: 10pt;
      color: #555;
    }

    .contact {
      font-size: 11pt;
      margin-bottom: 6px;
    }

    .skills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .skill-item {
      background: #4CAF50;
      color: #fff;
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 10pt;
    }
  </style>
</head>

<body>

  <header>
    <h1>{{name}}</h1>
    <h2>{{role}}</h2>
    {{#if contacts}}<p class="contact">{{formatContacts contacts format}}</p>{{/if}}
    {{#if summary}}<p>{{summary}}</p>{{/if}}
  </header>

  {{#if skills}}
  <section class="section">
    <h3>{{@root.labels.skills}}</h3>
    <div class="skills">
      {{#each skills}}<span class="skill-item">{{this}}</span>{{/each}}
    </div>
  </section>
  {{/if}}

  {{#if experiences}}
  <section class="section">
    <h3>{{@root.labels.experience}}</h3>
    {{#each experiences}}
    <div class="section">
      <p class="job-title">{{title}}</p>
      <p class="company-period">{{company}} | {{period}}</p>
      {{#if responsibilities}}<ul>{{#each responsibilities}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
      {{#if technologies}}<p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless
        @last}}, {{/unless}}{{/each}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if projects}}
  <section class="section">
    <h3>{{@root.labels.projects}}</h3>
    {{#each projects}}
    <div class="section">
      <p class="job-title">{{name}}</p>
      {{#if highlights}}<ul>{{#each highlights}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
      {{#if technologies}}<p><strong>{{@root.labels.technologies}}:</strong> {{#each technologies}}{{this}}{{#unless
        @last}}, {{/unless}}{{/each}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

</body>

</html>